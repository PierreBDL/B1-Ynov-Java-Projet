<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="b1ynovjavaprojet.b1ynovjavaprojet.PlusMoinsController"
      stylesheets="@style.css" styleClass="main-container">
    
    <Button text="Retour au menu" onAction="#switchToMenu" styleClass="back-button"/>

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <Label text="Jeu du Plus ou Moins" styleClass="title-label"/>
    <Label text="Devinez le nombre entre 1 et 1000" styleClass="instruction-label"/>

    <HBox alignment="CENTER" spacing="10.0">
        <TextField fx:id="inputField" promptText="Entrez un nombre..." prefWidth="150"/>
        <Button text="Valider" onAction="#onValidateClick" styleClass="validate-button"/>
    </HBox>

    <Label fx:id="resultLabel" text="" styleClass="result-label"/>
    
    <Label fx:id="scoreLabel" text="Tentatives : 0" styleClass="score-label"/>
    
    <Button text="Rejouer" onAction="#onResetClick" styleClass="back-button"/>
</VBox>