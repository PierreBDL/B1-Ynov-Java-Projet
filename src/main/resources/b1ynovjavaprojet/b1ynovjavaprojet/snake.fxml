<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>

<StackPane fx:id="gameRoot" xmlns:fx="http://javafx.com/fxml" 
           fx:controller="b1ynovjavaprojet.b1ynovjavaprojet.SnakeController" 
           style="-fx-background-color: black;">

    <VBox alignment="CENTER" spacing="10">
        <Label text="Score: 0" fx:id="scoreLabel" textFill="white" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        
        <StackPane style="-fx-border-color: #30363d; -fx-border-width: 2;">
             <Canvas fx:id="canvas" width="800" height="600" />
        </StackPane>
    </VBox>

    <VBox fx:id="gameOverOverlay" visible="false" alignment="CENTER" spacing="20" 
          style="-fx-background-color: rgba(0, 0, 0, 0.85);">
        <Label text="GAME OVER" textFill="white" style="-fx-font-size: 60px; -fx-font-weight: bold;" />
        <Label fx:id="finalScoreLabel" text="Score: 0" textFill="#e3b341" style="-fx-font-size: 32px;" />
        <Button text="Retour au menu" onAction="#switchToMenu" styleClass="game-button" />
    </VBox>
</StackPane>