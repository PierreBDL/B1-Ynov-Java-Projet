<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.shape.*?>

<StackPane fx:id="gameRoot" xmlns:fx="http://javafx.com/fxml"
    fx:controller="b1ynovjavaprojet.b1ynovjavaprojet.PacmanController"
    style="-fx-background-color: black;" stylesheets="@style.css">

    <StackPane fx:id="container" alignment="CENTER">
        <Canvas fx:id="canvas" width="672" height="416" />
        <Label text="Score: 0" fx:id="scoreLabel" textFill="white"
            StackPane.alignment="TOP_CENTER"
            style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 20 0 0 0;" />

        <Label fx:id="timerLabel" text="" textFill="#00FF00"
            StackPane.alignment="TOP_LEFT"
            style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 20 0 0 20;" />

        <HBox fx:id="healthContainer" alignment="TOP_RIGHT" spacing="5"
            StackPane.alignment="TOP_RIGHT" style="-fx-padding: 20 20 0 0;">
            <Label text="Health:" textFill="white" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <HBox fx:id="healthBar" spacing="5">
                <Rectangle fx:id="health1" width="20" height="20" fill="#FF0000" />
                <Rectangle fx:id="health2" width="20" height="20" fill="#FF0000" />
                <Rectangle fx:id="health3" width="20" height="20" fill="#FF0000" />
            </HBox>
        </HBox>

        <Button text="Pouvoir" fx:id="btnPouvoir" textFill="white"
            StackPane.alignment="BOTTOM_RIGHT"
            style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-margin: 20px 20px;"
            styleClass="game-button" onAction="#activerPouvoir" />

        <Button text="Retour au menu" onAction="#switchToMenu"
            StackPane.alignment="BOTTOM_CENTER"
            styleClass="menu-button" style="-fx-translate-y: -20;" />
    </StackPane>

    <VBox fx:id="gameOverOverlay" visible="false" alignment="CENTER" spacing="20"
        style="-fx-background-color: rgba(0, 0, 0, 0.85);">
        <Label text="GAME OVER" fx:id="LabelGameOver" textFill="white" style="-fx-font-size: 60px; -fx-font-weight: bold;" />
        <Label fx:id="finalScoreLabel" text="Score: 0" textFill="#e3b341"
            style="-fx-font-size: 32px;" />
        <Button text="Retour au menu" onAction="#switchToMenu" styleClass="game-button" />
    </VBox>
</StackPane>