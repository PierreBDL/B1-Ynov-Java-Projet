<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.canvas.Canvas?>

<VBox fx:id="gameRoot" alignment="CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="b1ynovjavaprojet.b1ynovjavaprojet.PacmanController" style="-fx-background-color: black;">

    <Label text="Score: 0" fx:id="scoreLabel" textFill="white" style="-fx-font-size: 20px;" />
    
    <StackPane prefWidth="640" prefHeight="416">
        <Canvas fx:id="canvas" width="640" height="416" />
        
        <Pane fx:id="gameOverOverlay" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.8);">
            <VBox alignment="CENTER" prefWidth="640" prefHeight="416">
                <Label text="GAME OVER" textFill="white" style="-fx-font-size: 48px; -fx-font-weight: bold;" />
                <Label fx:id="finalScoreLabel" text="Score: 0" textFill="white" style="-fx-font-size: 28px; -fx-padding: 20;" />
                <Button text="Retour au menu" onAction="#switchToMenu" style="-fx-font-size: 18px; -fx-padding: 10px 30px;" />
            </VBox>
        </Pane>
    </StackPane>

</VBox>