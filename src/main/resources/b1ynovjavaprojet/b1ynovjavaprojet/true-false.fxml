<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="30.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="b1ynovjavaprojet.b1ynovjavaprojet.TrueFalseController"
      stylesheets="@style.css" styleClass="true-false-container">

    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="10.0">
        <Label text="True or False" styleClass="game-title"/>
    </VBox>

    <VBox alignment="CENTER" spacing="20.0">
        <Label text="Question :" styleClass="question-label"/>
        <Label fx:id="questionLabel" text="Question affichée ici" styleClass="question-text" alignment="CENTER"/>
        <HBox alignment="CENTER" spacing="20.0">
            <Button text="Vrai" styleClass="answer-button" onAction="#handleTrueAnswer"/>
            <Button text="Faux" styleClass="answer-button" onAction="#handleFalseAnswer"/>
        </HBox>
        <Label fx:id="feedbackLabel" text="" styleClass="feedback-label"/>
        <Button text="Retour au menu" styleClass="menu-button" onAction="#switchToMenu"/>
    </VBox>
</VBox>
